# PostgreSQL connection string. The app rewrites the postgresql:// scheme to
# postgresql+asyncpg:// at runtime, so either form works here.
DATABASE_URL=postgresql://ship:ship@localhost:5432/ship

# Cloudflare R2 (S3-compatible) credentials.
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=ship-artifacts

# Public base URL of the R2 bucket (used for direct asset links, if needed).
R2_PUBLIC_URL=https://artifacts.example.com

# Public base URL where deployments are served. Used to build returned URLs.
PUBLIC_BASE_URL=http://localhost:8000

# Port uvicorn binds to.
PORT=8000
