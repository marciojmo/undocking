# PostgreSQL connection string. The app rewrites the postgresql:// scheme to
# postgresql+asyncpg:// at runtime, so either form works here.
DATABASE_URL=postgresql://ship:ship@localhost:5432/ship

# Cloudflare R2 (S3-compatible) credentials.
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=ship-artifacts

# Public base URL of the R2 bucket (used for direct asset links, if needed).
R2_PUBLIC_URL=https://artifacts.example.com

# Public base URL where deployments are served. Used to build returned URLs.
PUBLIC_BASE_URL=http://localhost:8000

# Port uvicorn binds to.
PORT=8000

# --- Dashboard auth (phase 2) ----------------------------------------------
# Signs the session cookie. Use a long random value in production, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=dev-insecure-session-secret-change-me

# Where the dashboard runs (users land here after signing in).
FRONTEND_URL=http://localhost:3000

# Browser-facing base URL of this API. In dev the Next.js app proxies /api/*
# to the API, so this points at the proxy. The OAuth redirect URI is
# "{PUBLIC_API_URL}/auth/callback/{provider}" — register that with the provider.
PUBLIC_API_URL=http://localhost:3000/api

# OAuth credentials. Set a provider's id AND secret to enable it (either or both).
# GitHub:  https://github.com/settings/developers (callback: PUBLIC_API_URL/auth/callback/github)
# Google:  https://console.cloud.google.com/apis/credentials (callback: PUBLIC_API_URL/auth/callback/google)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
